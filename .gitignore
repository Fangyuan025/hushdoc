# Local data + artifacts
chroma_db/
chat_history/
data/uploads/
eval_results/
models/*.gguf
runtime/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# IDE
.vscode/
.idea/
.DS_Store

# Runtime logs
*.log

# Frontend build artefacts (web/.gitignore also covers these, but be
# explicit so a stray git-add at the repo root doesn't slip them in).
web/node_modules/
web/dist/
web/.vite/
web/*.log


# Personal documents and stray test artefacts at repo root
/*.pdf
/*.err
.claude/

# Maintainer-only marketing source. The NotebookLM-ready
# introduction script is intended as input for video generation;
# it intentionally repeats README content in narration form and
# would just clutter the public repo if shipped.
introduction-of-hushdoc.md

# v0.3.0 user settings (Settings page persists here; never goes in git)
hushdoc_config.json

# Dev-only tests + test fixtures: kept locally for the maintainer,
# not shipped to users (the smoke / integration tests aren't part of
# the public UX, and ``data/attention.pdf`` is a copyrighted academic
# paper we can't redistribute).
#
# v0.6.5: ``evaluate.py`` IS shipped (it's advertised in README's
# Quality section), but the labelled test set itself stays local --
# the public eval scores in README come from the maintainer's
# private set; users supply their own ``{question, ground_truth}``
# JSON for their own domain.
eval_dataset.json
smoke_test.py
smoke_v*.py
test_api.py
web/tests/
data/attention.pdf
