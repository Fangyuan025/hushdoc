web/node_modules/
web/dist/
web/.vite/
web/*.log


# Personal documents and stray test artefacts at repo root
/*.pdf
/*.err
.claude/

# v0.3.0 user settings (Settings page persists here; never goes in git)
hushdoc_config.json

# Eval + dev-only tests + test fixtures: kept locally for the maintainer,
# not shipped to users (they don't need ragas / datasets / pyarrow for
# the chat path, and the smoke / integration tests aren't part of the UX).
evaluate.py
eval_dataset.json
smoke_test.py
test_api.py
data/attention.pdf
