# Local data + artifacts
chroma_db/
chat_history/
data/uploads/
eval_results/
models/*.gguf
runtime/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# IDE
.vscode/
.idea/
.DS_Store

# Runtime logs
*.log

# Frontend build artefacts (web/.gitignore also covers these, but be
# explicit so a stray git-add at the repo root doesn't slip them in).
web/node_modules/
web/dist/
web/.vite/
web/*.log


# Personal documents and stray test artefacts at repo root
/*.pdf
/*.err
.claude/

# v0.3.0 user settings (Settings page persists here; never goes in git)
hushdoc_config.json

# Dev-only tests + test fixtures: kept locally for the maintainer,
# not shipped to users (the smoke / integration tests aren't part of
# the public UX, and ``data/attention.pdf`` is a copyrighted academic
# paper we can't redistribute).
#
# v0.6.5: ``evaluate.py`` + ``eval_dataset.json`` are NOW shipped --
# they're advertised in README's Quality section so users need them
# to reproduce the scores. ``ragas`` + ``datasets`` ship in
# ``requirements-eval.txt`` (separate from the runtime requirements
# so the chat path stays slim).
smoke_test.py
smoke_v*.py
test_api.py
web/tests/
data/attention.pdf
