web/node_modules/
web/dist/
web/.vite/
web/*.log


# Personal documents and stray test artefacts at repo root
/*.pdf
/*.err
.claude/

# Eval + test fixtures: kept locally for development, not shipped to users
# (users don't need ragas / datasets / pyarrow for the chat path).
evaluate.py
eval_dataset.json
data/attention.pdf
